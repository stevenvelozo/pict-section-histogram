{
    "name": "pict-section-histogram",
    "version": "1.0.1",
    "description": "Pict histogram section with vertical/horizontal orientation, browser/consoleui/CLI rendering, and interactive selection",
    "main": "source/Pict-Section-Histogram.js",
    "scripts": {
        "start": "node source/Pict-Section-Histogram.js",
        "build": "npx quack build",
        "test": "npx quack test",
        "tests": "npx quack test -g",
        "coverage": "npx quack coverage"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fable-retold/pict-section-histogram.git"
    },
    "author": "steven velozo <steven@velozo.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/fable-retold/pict-section-histogram/issues"
    },
    "homepage": "https://github.com/fable-retold/pict-section-histogram#readme",
    "devDependencies": {
        "browser-env": "^3.3.0",
        "pict": "^1.0.372",
        "pict-docuserve": "^1.4.2",
        "quackage": "^1.2.5"
    },
    "mocha": {
        "diff": true,
        "extension": [
            "js"
        ],
        "package": "./package.json",
        "reporter": "spec",
        "slow": "75",
        "timeout": "5000",
        "ui": "tdd",
        "watch-files": [
            "source/**/*.js",
            "test/**/*.js"
        ],
        "watch-ignore": [
            "lib/vendor"
        ]
    },
    "dependencies": {
        "pict-view": "^1.0.68"
    }
}
