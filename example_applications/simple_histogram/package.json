{
	"name": "simple_histogram",
	"version": "1.0.0",
	"description": "Simple histogram example for pict-section-histogram",
	"main": "Simple-Histogram-Application.js",
	"scripts":
	{
		"start": "node Simple-Histogram-Application.js",
		"build": "npx quack build && npx quack copy"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"copyFilesSettings":
	{
		"whenFileExists": "overwrite"
	},
	"copyFiles":
	[
		{ "from": "./html/*", "to": "./dist/" },
		{ "from": "../../node_modules/pict/dist/*", "to": "./dist/" }
	],
	"dependencies":
	{
		"pict": "^1.0.293",
		"pict-application": "^1.0.19",
		"pict-view": "^1.0.63"
	}
}
